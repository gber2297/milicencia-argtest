# URL pública del sitio (sin barra final). En Docker/proxy evita redirects a 0.0.0.0.
# Podés usar APP_URL (solo servidor) o NEXT_PUBLIC_APP_URL.
APP_URL=

# Copiá estos valores desde el panel de Supabase (Settings → API).
# La service role solo se usa en el servidor; no la expongas al cliente.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Link de pago (Mercado Pago u otro checkout). Si está vacío o inválido, los CTAs de Premium van a /pricing.
NEXT_PUBLIC_MERCADOPAGO_CHECKOUT_URL=
