# URL pública del sitio (sin barra final). En Docker/proxy evita redirects a 0.0.0.0.
# Podés usar APP_URL (solo servidor) o NEXT_PUBLIC_APP_URL.
# En desarrollo local: dejá vacío o usá http://localhost:3000 (mismo puerto que next dev).
# Si ponés la URL de producción mientras corrés en localhost, el login te redirigiría al sitio en vivo.
APP_URL=

# Analítica propia (Supabase): POST /api/telemetry/event → tabla web_analytics_events (migración 004).
# Requiere SUPABASE_SERVICE_ROLE_KEY en el servidor (Vercel: Environment Variables, sin NEXT_PUBLIC).
# Captura: por hostname (no localhost). Opcional: restringir al dominio público (coma-separado).
# NEXT_PUBLIC_ANALYTICS_ALLOWED_HOSTS=tudominio.com,www.tudominio.com
# Para forzar envío a Supabase también en local (probar): true
# NEXT_PUBLIC_ANALYTICS_CAPTURE_DEV=true
# En el navegador abrí la consola: si ves [telemetry] no_service_role, falta esa variable en el deploy.
# NEXT_PUBLIC_ANALYTICS_DEBUG=true  (opcional: ver avisos de telemetry en producción)
# Para desactivar el tracking en cliente: false
# NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Panel /dev/analytics (lectura de eventos). Igual que Studio: activo en `next dev`, off en prod.
# Para habilitar el panel en un deploy: NEXT_PUBLIC_ANALYTICS_DASHBOARD_ENABLED=true
# NEXT_PUBLIC_ANALYTICS_DASHBOARD_ENABLED=

# Opcional: scripts de terceros (no hace falta si solo usás analítica propia).
# GA4: Measurement ID tipo G-XXXXXXXXXX
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Plausible: dominio registrado en Plausible (ej. milicencia.app)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Copiá estos valores desde el panel de Supabase (Settings → API).
# La service role solo se usa en el servidor; no la expongas al cliente.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Link de pago plan mensual (Mercado Pago u otro). Si está vacío o inválido, los CTAs van a /pricing.
NEXT_PUBLIC_MERCADOPAGO_CHECKOUT_URL=

# Suscripción Mercado Pago — plan semanal (preapproval). Si está vacío, se usa el plan por defecto en código.
NEXT_PUBLIC_MERCADOPAGO_CHECKOUT_URL_SEMANAL=

# --- Suscripciones vía API (preapproval + webhook) — opcional ---
# Si activás esto, la app usa POST /api/billing/mp-subscribe y sincroniza con webhooks.
# En el panel de Mercado Pago: Tus integraciones → Webhooks → URL: {APP_URL}/api/billing/mercadopago-webhook
# Creá dos planes en MP y pegá sus preapproval_plan_id (uno semanal, uno mensual).
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...   (credencial de producción o test; solo servidor, nunca NEXT_PUBLIC)
# IDs de plan (opcional): solo si usás links manuales o querés crear planes en el panel. El flujo API
# /api/billing/mp-subscribe usa suscripción SIN plan asociado + pending (montos abajo).
# MERCADOPAGO_PREAPPROVAL_PLAN_ID_WEEKLY=
# MERCADOPAGO_PREAPPROVAL_PLAN_ID_MONTHLY=
# Montos ARS para POST /preapproval (mismo criterio que la página de precios):
# MERCADOPAGO_PLAN_AMOUNT_WEEKLY=4990
# MERCADOPAGO_PLAN_AMOUNT_MONTHLY=8990
# Prueba en prod con monto mínimo solo para un email (luego borrá estas dos líneas):
# MERCADOPAGO_TEST_CHECKOUT_EMAIL=tu-cuenta@gmail.com
# MERCADOPAGO_TEST_AMOUNT_ARS=1
# MERCADOPAGO_PLAN_BACK_URL=https://tu-dominio.com/pricing
# URL de retorno tras pagar en MP (debe ser https válida). Si MP rechaza localhost, usá tu dominio de prod:
# MERCADOPAGO_BACK_URL=https://tu-dominio.com/pricing?mp=1
# En el cliente (paywall, nav): mismo modo que el servidor para los CTAs con formulario.
# NEXT_PUBLIC_MERCADOPAGO_SUBSCRIPTIONS_API=true

# Blotato (subida de video a redes). Opcional en desarrollo.
# BLOTATO_API_KEY=
# BLOTATO_ACCOUNT_ID=
# TikTok (post.target en API v2): por defecto privacyLevel=PUBLIC_TO_EVERYONE
# BLOTATO_TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# Video Studio (rutas /studio y /api/studio). En producción está OFF por defecto.
# En local con `next dev` no hace falta. Para desactivar también en dev: false
# Para habilitar en un deploy: true
# NEXT_PUBLIC_STUDIO_ENABLED=false

# Guion marketing + narrativo error/motivación/datos/storytelling (full_ia). Opcional: OPENAI_MARKETING_MODEL, OPENAI_NARRATIVE_MODEL
# OPENAI_API_KEY=

# Imágenes de stock para fondos (lib/studio/resolve-scene-image.ts + npm run studio:resolve-image).
# Orden: Pexels → Unsplash → URLs fijas por palabras clave. Sin claves: solo fallback estático.
# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=
